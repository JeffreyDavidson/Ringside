{
    "name": "jeffreydavidson/ringside",
    "type": "project",
    "description": "A project to help wrestling promoters run their companies.",
    "keywords": [
        "laravel",
        "wrestling"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ankurk91/laravel-eloquent-relationships": "^2.2",
        "calebporzio/sushi": "^2.5",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10.1",
        "livewire/livewire": "^3.5",
        "lorisleiva/laravel-actions": "^2.9"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.15",
        "barryvdh/laravel-ide-helper": "^3.5",
        "christophrumpel/missing-livewire-assertions": "^2.11",
        "driftingly/rector-laravel": "^2.0",
        "fakerphp/faker": "^1.23",
        "filp/whoops": "^2.14",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^1.0",
        "laravel/breeze": "^2.3",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-browser": "^4.0",
        "pestphp/pest-plugin-faker": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "povils/phpmnd": "^3.4",
        "rector/rector": "^2.0",
        "spatie/laravel-ignition": "^2.9"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": false,
            "dealerdirect/phpcodesniffer-composer-installer": false,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "rector": "rector",
        "lint": "pint",
        "test:rector": "rector --dry-run",
        "test:lint": "pint --test",
        "test:types": "phpstan analyze --memory-limit=4G --ansi",
        "test:unit": "php -d memory_limit=4G ./vendor/bin/pest --colors=always --parallel --coverage --exactly=100",
        "test:type-coverage": "php -d memory_limit=4G ./vendor/bin/pest --type-coverage --min=100",
        "test": [
            "@test:type-coverage",
            "@test:rector",
            "@test:lint",
            "@test:types",
            "@test:unit"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ]
    }
}
